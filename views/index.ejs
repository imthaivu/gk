<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Menu quan ca phe</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        .card-img-top {
            height: 180px;
            object-fit: cover;
        }
    </style>
</head>

<body class="bg-light">
    <div class="container py-4">
        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2 mb-3">
            <div>
                <h1 class="h4 mb-0">Menu quan ca phe</h1>
                <small class="text-muted">Tim kiem, loc va quan ly mon an/uong</small>
            </div>
            <a class="btn btn-primary" href="/menu/create">+ Them mon</a>
        </div>

        <% if (flash) { %>
            <div class="alert alert-<%= flash.type %>">
                <%= flash.text %>
            </div>
            <% } %>

                <form class="row g-2 align-items-end mb-3" method="get">
                    <div class="col-md-4">
                        <label class="form-label">Tim theo ten mon</label>
                        <input class="form-control" type="text" name="q" value="<%= q || '' %>" placeholder="Nhap ten mon..." />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Loai mon</label>
                        <select class="form-select" name="category">
          <option value="">Tat ca</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat %>" <%= category === cat ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Trang thai</label>
                        <select class="form-select" name="isAvailable">
          <option value="">Tat ca</option>
          <option value="true" <%= availability === 'true' ? 'selected' : '' %>>Con ban</option>
          <option value="false" <%= availability === 'false' ? 'selected' : '' %>>Het mon</option>
        </select>
                    </div>
                    <div class="col-md-2 d-flex gap-2">
                        <button class="btn btn-dark w-100" type="submit">Loc</button>
                        <a class="btn btn-outline-secondary w-100" href="/menu">Reset</a>
                    </div>
                </form>

                <div class="row g-2 mb-4">
                    <% (availableByCategory || []).forEach(stat => { %>
                        <div class="col-6 col-md-3">
                            <div class="border rounded p-2 text-center bg-white">
                                <div class="fw-semibold">
                                    <%= stat.category %>
                                </div>
                                <div class="text-success">
                                    <%= stat.count %> mon con ban</div>
                            </div>
                        </div>
                        <% }) %>
                </div>

                <div class="row g-3">
                    <% if (!items || !items.length) { %>
                        <div class="col-12">
                            <div class="alert alert-info">Chua co mon nao. Bam "Them mon" de tao moi.</div>
                        </div>
                        <% } %>

                            <% (items || []).forEach(item => { %>
                                <div class="col-md-4 col-lg-3">
                                    <div class="card h-100">
                                        <img class="card-img-top" src="<%= item.imageUrl %>" alt="<%= item.itemName %>" onerror="this.src='https://placehold.co/400x300?text=No+Image'" />
                                        <div class="card-body d-flex flex-column">
                                            <h5 class="card-title mb-1">
                                                <%= item.itemName %>
                                            </h5>
                                            <div class="text-muted mb-2">
                                                <%= item.category %>
                                            </div>
                                            <div class="mb-2">
                                                <div class="fw-semibold text-decoration-line-through text-muted">
                                                    <%= item.price.toLocaleString('vi-VN') %> VND</div>
                                                <div class="fw-bold text-danger">Gia sau giam:
                                                    <%= item.salePrice.toLocaleString('vi-VN') %> VND</div>
                                                <small class="text-muted">Giam <%= item.discountPercent %>%</small>
                                            </div>
                                            <div class="mb-2">
                                                <span class="badge <%= item.isAvailable ? 'bg-success' : 'bg-secondary' %>"><%= item.isAvailable ? 'Con ban' : 'Het mon' %></span>
                                            </div>
                                            <div class="mt-auto d-flex gap-2">
                                                <a class="btn btn-outline-primary btn-sm w-100" href="/menu/<%= item.itemId %>">Xem</a>
                                                <a class="btn btn-outline-warning btn-sm w-100" href="/menu/<%= item.itemId %>/edit">Sua</a>
                                                <form action="/menu/<%= item.itemId %>/delete" method="post" class="w-100" onsubmit="return confirm('Xoa mon nay?');">
                                                    <button class="btn btn-outline-danger btn-sm w-100" type="submit">Xoa</button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <% }) %>
                </div>
    </div>
</body>

</html>